{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "typeRoots": ["./node_modules/@types", "./src/types"],  
    "moduleResolution": "node",
    "outDir": "dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src"]
}
