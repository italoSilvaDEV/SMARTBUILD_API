generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {

  id                     String    @id @default(uuid())
  avatar                 String?
  name                   String
  email                  String    @unique
  document               String    @unique
  phone                  String?
  city_and_state         String?
  password               String
  rules                  Json
  token_recover_password String?   @unique
  autorId                String?
  last_acess             DateTime?
  date_creation          DateTime  @default(now())
  date_update            DateTime  @updatedAt
  office                 Office    @relation(fields: [office_id], references: [id])
  office_id              String
}

model Office {
  id            String   @id @default(uuid())
  name          String
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
  User          User[]
}

model Rules {
  id            String   @id @default(uuid())
  name          String
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

}

model Category {
  id String @id @default(uuid())

  type_category String //residencial || comercial
  category_img String?
  status_category Boolean ?
  category_name    String

  autorId       String?
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  sub_category SubCategory[]

  @@map("service")
}

model SubCategory {
  id String @id @default(uuid())

  status_subcategory       Boolean ?
  subcategory_name String

  autorId       String?
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  subcategory Category @relation(fields: [category_id], references: [id])
  category_id String

  service Service[]

  @@map("subcategory")
}

model Service {
  id String @id @default(uuid())

  service_name String
  type_variable String //produto ou medir(measure/product)
  price_type    String //fixe ou variável(fixe/variable)

  price_fixe    Decimal?
  price_minimum Decimal?
  price_maximum Decimal?

  service         SubCategory @relation(fields: [sub_category_id], references: [id])
  sub_category_id String

  autorId       String?
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  @@map("variable_service")
}
