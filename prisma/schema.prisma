enum TypeInvoiceBase {
  project
  estimate
}

enum AttendanceMode {
  manual
  auto
}

model Invoice {
  id                    String  @id @default(uuid())
  stripeInvoiceId       String? @unique
  stripePaymentIntentId String? @unique // NOVO: para Payment Element
  externalInvoiceId     String?

  checked       Boolean? @default(false)
  ignoreChecked Boolean? @default(false)

  invoiceType       String? // "stripe", "quickbooks", "custom"
  invoiceTypeStripe String? // "invoice", "payment_element" (apenas para invoiceType = "stripe")
  status            String // Status: draft, open, paid, partial (QBO only), void, uncollectible
  totalAmount       Decimal
  currency          String    @default("usd") // NOVO: suporte a múltiplas moedas
  dueDate           DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  invoiceUrl        String?   @db.Text // Suporta URLs longas do QuickBooks
  
  // ===== CAMPOS PARA PAGAMENTOS PARCIAIS QBO (Fonte de verdade: QuickBooks) =====
  balanceRemaining          Decimal?  // Saldo restante (Balance do QBO)
  totalAmountPaidQbo        Decimal?  // Total já pago (TotalAmt - Balance do QBO)
  amountChangedAfterPayment Boolean   @default(false) // Se o valor foi alterado após pagamento
  lastPaymentAt             DateTime? // Data do último pagamento recebido

  type_invoicebase TypeInvoiceBase? @default(project)
  multi_emails     String?          @db.Text

  type_value          String? // "percentage" ou "value"
  cancel_invoice_edit Boolean? //se o invoice do tipo stripe for editado essa coluna deve ser true para que o stripe possa gerar um novo invoice

  percentageCoefficient Decimal?
  description           String?  @db.Text

  // Campos específicos para QuickBooks
  externalDocNumber String?
  idQuickBooksRef   String? // ID do invoice no QuickBooks quando criado via integração

  // Campos específicos para QuickBooks Contábil (quando chamado pelo StripeController)
  idQuickbookContabio         String? // ID do invoice no QuickBooks criado via Stripe
  docNumberQuickBooksContabio String? // Número do documento QuickBooks criado via Stripe

  // NOVOS CAMPOS PARA PAYMENT INTENT
  paymentMethodType        String? // Tipo do método de pagamento usado (card, us_bank_account, etc.)
  totalAmountPaid          Decimal? // Valor total pago (inclui surcharge)
  surchargePaymentLocal    Decimal? // Taxa local aplicada (diferença entre valor original e final)
  surchargePaymentStripe   Decimal? // Taxa de processamento cobrada pelo Stripe
  totalAmountWithSurcharge Decimal? // Valor total pago (com surcharge)

  // Relacionamento com Project e Company
  project   Project? @relation(name: "ProjectToInvoice", fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  company   Company? @relation(name: "CompanyToInvoice", fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?

  user_create User?   @relation(fields: [user_id], references: [id])
  user_id     String?

  estimate           Estimate?            @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId         String?
  // Relacionamentos
  InvoiceSendHistory InvoiceSendHistory[]
  InvoiceItems       InvoiceItem[] // Nova relação com InvoiceItem

  InvoiceTimeline     InvoiceTimeline[]
  InvoiceEmailLog     InvoiceEmailLog[]
  InvoiceAutoEmailLog InvoiceAutoEmailLog[]

  // Relação com CustomInvoicePayment (uma fatura pode ter um pagamento)
  payment    InvoicePayment?
  
  // NOVO: Pagamentos parciais QBO
  paymentApplications PaymentApplication[]
  
  PdfProject PdfProject[]

  // Relacionamento com fildsPdfProject
  fildsPdfProjects fildsPdfProject[]

  // NOVO: Relacionamento com PaymentIntentRecord (para Payment Element)
  PaymentIntents    PaymentIntentRecord[]
  pdfInvoicePaids   PdfInvoicePaid?
  imagesAttachments ImagesAttachments[]

  @@index([externalInvoiceId, invoiceType])
}

model InvoiceSendHistory {
  id        String   @id @default(uuid())
  sentAt    DateTime @default(now())
  recipient String

  // Relacionamento com Invoice
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  user_create User?   @relation(fields: [user_id], references: [id])
  user_id     String?
}

model QuickBooksAccount {
  id                   String    @id @default(uuid())
  accessToken          String    @db.Text
  refreshToken         String    @db.Text
  realmId              String    @unique
  expiresAt            DateTime
  refreshExpiresAt     DateTime? // <- novo (opcional)
  needsReauthorization Boolean   @default(false)
  isDisabled           Boolean   @default(false)
  scopes               String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User?     @relation(fields: [user_id], references: [id])
  user_id              String?   @unique
  companyName          String?
  companyAddress       String?   @db.Text
  companyPhone         String?
  companyEmail         String?
  taxIdentifier        String?
  businessType         String?

  company    Company? @relation(fields: [company_id], references: [id])
  company_id String?  @unique
}

model InvoiceItem {
  id          String   @id @default(uuid())
  name        String // Nome do serviço ou item
  description String?  @db.Text // Descrição opcional do item
  quantity    Decimal // Quantidade REAL (ex: 30) - usado para exibição e edição
  price       Decimal // Preço unitário REAL (ex: 200) - usado para exibição e edição
  totalAmount Decimal // Valor total (quantidade * preço)
  
  //  Campos para guardar o que foi enviado especificamente para QuickBooks
  // Quando invoice é QuickBooks, estes campos guardam os valores ajustados enviados ao QBO
  // Para Custom/Stripe, estes campos ficam NULL
  qboQuantity Decimal? // Quantidade enviada para QBO (sempre 1)
  qboPrice    Decimal? // Preço ajustado enviado para QBO (ex: 6000 = 30 * 200)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamento com Invoice
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String

  @@index([invoiceId])
}

model InvoicePayment {
  id            String   @id @default(uuid())
  paymentMethod String
  notes         String?  @db.Text
  amount        Float
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relação com Invoice (um pagamento pertence a uma fatura)
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String  @unique // Cada fatura pode ter apenas um registro de pagamento
}

// ===== PAGAMENTOS PARCIAIS QUICKBOOKS =====
// PaymentTransaction: Representa um pagamento recebido no QuickBooks
model PaymentTransaction {
  id                String   @id @default(uuid())
  provider          String   // "qbo"
  externalPaymentId String   // Payment.Id do QBO
  currency          String   @default("USD")
  totalAmount       Decimal  // Valor total do pagamento
  paymentMethodType String?  // Tipo de método de pagamento (Cash, Check, CreditCard, etc.)
  txnDate           DateTime? // Data da transação no QBO
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relacionamento com Company
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  
  // Relacionamento com PaymentApplication (um pagamento pode ser aplicado a várias invoices)
  applications PaymentApplication[]
  
  @@unique([provider, externalPaymentId])
  @@index([companyId])
}

// PaymentApplication: Representa quanto de um pagamento foi aplicado a uma invoice
model PaymentApplication {
  id                    String   @id @default(uuid())
  paymentTransactionId  String
  invoiceId             String
  amountApplied         Decimal  // Valor aplicado a esta invoice específica
  appliedAt             DateTime @default(now())
  
  // Relacionamentos
  paymentTransaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)
  invoice            Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  @@unique([paymentTransactionId, invoiceId])
  @@index([invoiceId])
  @@index([paymentTransactionId])
}

enum TypeEstimate {
  estimate
  estimateProject
}

model Estimate {
  id              String   @id @default(uuid())
  number          String
  approvedAt      DateTime @default(now())
  clientSignature String?  @db.Text
  totalAmount     Decimal
  description     String?  @db.Text
  terms           String?  @db.Text
  status          String   @default("pending")

  amountPaid Decimal? @default(0)
  balanceDue Decimal?

  pdf_needs_update Boolean? @default(false)

  type_estimate TypeEstimate? @default(estimateProject)
  multi_emails  String?       @db.Text

  canceledAt         DateTime?
  canceledById       String?
  cancellationReason String?   @db.Text

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  canceledBy User? @relation(name: "canceledEstimates", fields: [canceledById], references: [id], onDelete: Cascade)

  serviceProjects EstimateServiceProject[]
  timelineEvents  EstimateTimeline[]
  date_creation   DateTime                 @default(now())
  date_update     DateTime                 @updatedAt

  emailLogs  EstimateEmailLog[]
  PdfProject PdfProject[]

  // Relacionamento com fildsPdfProject
  fildsPdfProjects       fildsPdfProject[]
  Invoice                Invoice[]
  InvoicePaymentTimeLine InvoicePaymentTimeLine[]
  changeOrders           ChangeOrder[]
  imagesAttachments      ImagesAttachments[]

  @@unique([number, projectId])
