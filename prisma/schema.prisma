generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Config {
  id                  String  @id @default(uuid())
  multiCompanyEnabled Boolean @default(false)
}

model User {
  id              String   @id @default(uuid())
  avatar          String?
  name            String
  email           String   @unique
  document        String?
  phone           String?
  phone_emergency String?
  zip_code        String?
  city_and_state  String?
  state           String?
  number_road     String?
  number_home     String?
  neighborhood    String?
  password        String
  rules           Json
  hourly_price    Float?
  profession      String?
  isDisabled      Boolean? @default(false)
  isOverTime      Boolean? @default(false)

  token_recover_password String?              @unique
  autorId                String?
  last_acess             DateTime?
  date_creation          DateTime             @default(now())
  date_update            DateTime             @updatedAt
  office_id              String
  office                 Office               @relation(fields: [office_id], references: [id])
  userLikedCostProject   CostProject[]        @relation("userLikedProject")
  seller_project         Project[]            @relation("seller")
  ServiceStages          ServiceStages[]
  projectId              String?
  UserServiceProject     UserServiceProject[]
  UserAttendance         UserAttendance[]
  Activities             Activities[]

  InvoiceSendHistory InvoiceSendHistory[]

  // Relacionamento original 1:N (mantido)
  company    Company? @relation(fields: [company_id], references: [id])
  company_id String?

  // Nova relação N:N através da tabela UserCompany
  companies UserCompany[]

  Invoice  Invoice[]
  TimeLine TimeLine[]

  quickBooksAccount    QuickBooksAccount?
  quickBooksAccount_id String?            @unique

  canceledEstimates Estimate[] @relation("canceledEstimates")
  Audit             Audit[]

  SyncPreferences SyncPreferences[] @relation("SyncPreferences")
  SyncStatus      SyncStatus[]      @relation("SyncStatus")

  @@index([office_id], map: "User_office_id_fkey")
}

model Audit {
  id            String   @id @default(uuid())
  action        String   @db.Text
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
  userId        String
}

model Company {
  id            String   @id @default(uuid())
  avatar        String?
  name          String
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
  address       String?
  district      String?
  numberHouse   String?
  complement    String?
  email         String?
  phone         String?
  webSiteUrl    String?
  workStartTime String? // Format: "HH:mm" (24-hour)
  workEndTime   String? // Format: "HH:mm" (24-hour)

  // Relacionamento original 1:N (mantido)
  User User[]

  // Nova relação N:N através da tabela UserCompany
  userCompanies UserCompany[]

  Category         Category[]
  SubCategory      SubCategory[]
  Service          Service[]
  ServiceProject   ServiceProject[]
  Catalog          Catalog[]
  Project          Project[]
  Client           Client[]
  UserAttendance   UserAttendance[]
  allowedEmployees Int? // Quantidade de funcionários permitida pelo plano
  extraEmployees   Int? // Quantidade de funcionários extras adicionados

  invoices Invoice[] @relation(name: "CompanyToInvoice")

  NotesContrac ContractNotes[]

  stripeCustomerId String?

  // novo campo
  stripeAccountId String? @unique

  Subscription Subscription[]
  Plan         Plan?          @relation(fields: [planId], references: [id])
  planId       String?

  SyncPreferences   SyncPreferences[]  @relation("SyncPreferences")
  QuickBooksAccount QuickBooksAccount?

  SyncLog    SyncLog[]    @relation("synclog")
  SyncStatus SyncStatus[] @relation("SyncStatus")
}

model ContractNotes {
  id String @id @default(uuid())

  notes String @db.Text

  company    Company? @relation(fields: [company_id], references: [id])
  company_id String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Webhooks {
  id        String   @id @default(uuid())
  name      String // Nome do webhook
  event     String // Evento monitorado (ex.: checkout.session.completed)
  secret    String // Segredo do webhook
  url       String // URL associada ao webhook
  status    String // Status do webhook (ex.: "enabled", "disabled")
  stripeId  String   @unique // ID do webhook no Stripe
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // isConnectWebhook Boolean @default(false)

  @@map("webhooks")
}

model Office {
  id            String        @id @default(uuid())
  name          String
  date_creation DateTime      @default(now())
  date_update   DateTime      @updatedAt
  User          User[]
  UserCompany   UserCompany[]
}

model Rules {
  id            String   @id @default(uuid())
  name          String
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
}

model Category {
  id              String        @id @default(uuid())
  status_category Boolean?
  category_name   String
  autorId         String?
  date_creation   DateTime      @default(now())
  date_update     DateTime      @updatedAt
  category_img    String?
  type_category   String
  sub_category    SubCategory[]
  company         Company?      @relation(fields: [company_id], references: [id])
  company_id      String?

  @@map("service")
}

model SubCategory {
  id                 String    @id @default(uuid())
  status_subcategory Boolean?
  subcategory_name   String
  autorId            String?
  date_creation      DateTime  @default(now())
  date_update        DateTime  @updatedAt
  category_id        String
  subcategory        Category  @relation(fields: [category_id], references: [id])
  service            Service[]
  company            Company?  @relation(fields: [company_id], references: [id])
  company_id         String?

  @@index([category_id], map: "subcategory_category_id_fkey")
  @@map("subcategory")
}

model Service {
  id                     String                   @id @default(uuid())
  service_name           String
  type_variable          String
  price_type             String
  price_fixe             Decimal?
  price_minimum          Decimal?
  price_maximum          Decimal?
  autorId                String?
  date_creation          DateTime                 @default(now())
  date_update            DateTime                 @updatedAt
  service                SubCategory              @relation(fields: [sub_category_id], references: [id])
  sub_category_id        String
  ServiceProject         ServiceProject[]
  company                Company?                 @relation(fields: [company_id], references: [id])
  company_id             String?
  description            String?                  @db.Text
  EstimateServiceProject EstimateServiceProject[]

  @@index([sub_category_id], map: "variable_service_sub_category_id_fkey")
  @@map("variable_service")
}

model ServiceProject {
  id          String  @id @default(uuid())
  name        String
  description String  @db.Text
  hours       Decimal
  price       Decimal
  status      String?
  start_date  String?
  deadline    String?

  service    Service? @relation(fields: [id_service], references: [id])
  id_service String?

  stages             ServiceStages[]
  galleryBefore      GalleryBefore[]
  galleryAlfter      GalleryAfter[]
  photos             ImgServiceProject[]
  costProject        CostProject[]
  date_creation      DateTime             @default(now())
  date_update        DateTime             @updatedAt
  Project            Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId          String?
  UserServiceProject UserServiceProject[]
  Activities         Activities[]
  company            Company?             @relation(fields: [company_id], references: [id])
  company_id         String?
  TimeLine           TimeLine[]
}

model Activities {
  id   String @id @default(uuid())
  text String

  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?

  author   User?   @relation(fields: [authorId], references: [id])
  authorId String?

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
}

model ImgServiceProject {
  id               String          @id @default(uuid())
  uri              String          @unique
  date_creation    DateTime        @default(now())
  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?
}

model Catalog {
  id            String   @id @default(uuid())
  catalog_img   String?
  catalog_name  String
  autorId       String?
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  imgCatalog ImgCatalog[]
  company    Company?     @relation(fields: [company_id], references: [id])
  company_id String?

  @@map("catalog")
}

model ImgCatalog {
  id  String @id @default(uuid())
  uri String @unique

  data_criacao DateTime @default(now())
  authorId     String?

  catalog    Catalog @relation(fields: [catalog_id], references: [id])
  catalog_id String

  @@map("imgcatalog")
}

model Project {
  id                 String               @id @default(uuid())
  contract_number    Int?
  price              Decimal
  status_project     String
  autorId            String?
  start_date         String?
  deadline           String?
  date_creation      DateTime             @default(now())
  date_update        DateTime             @updatedAt
  invoiceCostProject InvoiceCostProject[]
  serviceProject     ServiceProject[]
  workedHours        Workedhours[]
  pdfproject         PdfProject[]
  contractProject    ContractProject[]
  estimates          Estimate[]

  amountPaid Decimal? @default(0)
  balanceDue Decimal? @default(0)

  invoices Invoice[] @relation(name: "ProjectToInvoice")

  client    Client? @relation(fields: [client_id], references: [id])
  client_id String?

  user           User?    @relation("seller", fields: [seller_user_id], references: [id])
  seller_user_id String?
  company        Company? @relation(fields: [company_id], references: [id])
  company_id     String?

  radius                 Float?
  location               String?                  @db.Text
  log                    String?                  @db.VarChar(191)
  lat                    String?                  @db.VarChar(191)
  InvoicePaymentTimeLine InvoicePaymentTimeLine[]

  @@index([client_id], map: "project_client_id_fkey")
  @@index([seller_user_id], map: "project_seller_user_id_fkey")
  @@map("project")
}

model ContractProject {
  id                 String   @id @default(uuid())
  original_file_name String?
  uri                String?
  date_creation      DateTime @default(now())
  date_update        DateTime @updatedAt

  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?

  @@map("contract_project")
}

model ServiceStages {
  id            String   @id @default(uuid())
  description   String
  check         Boolean  @default(false)
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  user             User            @relation(fields: [id_user_update], references: [id])
  id_user_update   String
  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?
}

model GalleryBefore {
  id               String          @id @default(uuid())
  url              String
  title            String?
  description      String?
  date_creation    DateTime        @default(now())
  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?
}

model GalleryAfter {
  id               String          @id @default(uuid())
  url              String
  title            String?
  description      String?
  date_creation    DateTime        @default(now())
  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?
}

model PdfProject {
  id                 String  @id @default(uuid())
  original_file_name String?
  uri                String?

  project    Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String?

  // vinculo com estimate
  estimate    Estimate? @relation(fields: [estimate_id], references: [id], onDelete: Cascade)
  estimate_id String?

  // vinculo com invoice
  invoice    Invoice? @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id String?

  type_pdf String?

  // Relacionamento com fildsPdfProject
  fildsPdfProjects fildsPdfProject[]

  autorId       String?
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  @@map("pdf_project")
}

model fildsPdfProject {
  id          String  @id @default(uuid())
  sections    String
  description String? @db.Text

  // Relacionamentos
  pdfProject   PdfProject? @relation(fields: [pdfProjectId], references: [id], onDelete: Cascade)
  pdfProjectId String?

  estimate   Estimate? @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId String?

  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String?

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
}

model Client {
  id               String    @id @default(uuid())
  avatar           String?
  name             String
  email            String
  document         String?
  phone            String?
  city_and_state   String?
  birth_date       String?
  location         String?   @db.Text
  lat              String?
  log              String?
  radius           Float?
  autorId          String?
  date_creation    DateTime  @default(now())
  date_update      DateTime  @updatedAt
  projects         Project[]
  company          Company?  @relation(fields: [company_id], references: [id])
  company_id       String?
  stripeCustomerId String?
  sync_version     Int       @default(0)

  quickbooksUpdatedAt DateTime?

  idQuickbooks          String?
  QuickBooksCustomerRaw QuickBooksCustomerRaw[]

  @@unique([idQuickbooks, company_id])
  @@unique([email, company_id])
}

model InvoiceCostProject {
  id                          String        @id @default(uuid())
  original_file_name          String?
  uri                         String?
  project_cost_invoice_exists Boolean
  autorId                     String?
  date_creation               DateTime      @default(now())
  date_update                 DateTime      @updatedAt
  project_id                  String?
  costProject                 CostProject[]
  project                     Project?      @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id], map: "invoice_cost_project_project_id_fkey")
  @@map("invoice_cost_project")
}

model CostProject {
  id            String  @id @default(uuid())
  material_name String
  price         Decimal
  amout         Int

  transaction_type        String?
  userId                  String?
  autorId                 String?
  date_creation           DateTime            @default(now())
  date_update             DateTime            @updatedAt
  invoiceCostProject      InvoiceCostProject? @relation(fields: [invoice_cost_project_id], references: [id], onDelete: Cascade)
  invoice_cost_project_id String?
  user                    User?               @relation("userLikedProject", fields: [userId], references: [id])

  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?

  @@index([invoice_cost_project_id], map: "cost_project_invoice_cost_project_id_fkey")
  @@index([userId], map: "cost_project_userId_fkey")
  @@map("cost_project")
}

model Workedhours {
  id String @id @default(uuid())

  name_user String

  start_date String?

  end_date String?

  amount_of_hours Decimal?
  hourly_price    Decimal

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  project    Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String?

  @@map("worked_hours")
}

// Relacionamento entre User e ServiceProject
model UserServiceProject {
  id          String   @id @default(uuid())
  assigned_at DateTime @default(now())

  user    User   @relation(fields: [user_id], references: [id])
  user_id String

  service_project    ServiceProject @relation(fields: [service_project_id], references: [id], onDelete: Cascade)
  service_project_id String

  user_attendances UserAttendance[]
  TimeLine         TimeLine[]

  @@unique([user_id, service_project_id], map: "user_service_project_unique")
  @@index([user_id], map: "user_service_project_user_id_fkey")
  @@index([service_project_id], map: "user_service_project_service_project_id_fkey")
  @@map("user_service_project")
}

model UserAttendance {
  id                      String             @id @default(uuid())
  check_in_time           DateTime
  check_out_time          DateTime?
  check_in_address        String
  check_in_latitude       Float
  check_in_longitude      Float
  check_out_address       String?
  check_out_latitude      Float?
  check_out_longitude     Float?
  date                    DateTime           @default(now())
  user                    User               @relation(fields: [user_id], references: [id])
  user_id                 String
  UserServiceProject      UserServiceProject @relation(fields: [user_service_project_id], references: [id], onDelete: Cascade)
  user_service_project_id String
  company                 Company?           @relation(fields: [company_id], references: [id])
  company_id              String?

  workStartTime String? // Format: "HH:mm" (24-hour)
  workEndTime   String?

  isOvertime Boolean? @default(false)

  @@index([user_id], map: "user_attendance_user_id_fkey")
  @@index([user_service_project_id], map: "user_attendance_user_service_project_id_fkey")
  @@map("user_attendance")
}

model TimeLine {
  id                   String             @id @default(uuid())
  check_in_time        DateTime
  check_in_address     String
  check_in_latitude    Float
  check_in_longitude   Float
  is_local_work        Boolean
  date_creation        DateTime           @default(now())
  date_update          DateTime           @updatedAt
  user                 User               @relation(fields: [user_id], references: [id])
  user_id              String
  service_project      ServiceProject     @relation(fields: [service_project_id], references: [id], onDelete: Cascade)
  service_project_id   String
  UserServiceProject   UserServiceProject @relation(fields: [userServiceProjectId], references: [id], onDelete: Cascade)
  userServiceProjectId String
}

enum TypeInvoiceBase {
  project
  estimate
}

model Invoice {
  id                    String  @id @default(uuid())
  stripeInvoiceId       String? @unique
  stripePaymentIntentId String? @unique // NOVO: para Payment Element
  externalInvoiceId     String?

  invoiceType       String? // "stripe", "quickbooks", "custom"
  invoiceTypeStripe String? // "invoice", "payment_element" (apenas para invoiceType = "stripe")
  status            String // Status do invoice: draft, open, paid, void, uncollectible
  totalAmount       Decimal
  currency          String    @default("usd") // NOVO: suporte a múltiplas moedas
  dueDate           DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  invoiceUrl        String?

  type_invoicebase TypeInvoiceBase? @default(project)
  multi_emails     String?          @db.Text

  type_value          String? // "percentage" ou "value"
  cancel_invoice_edit Boolean? //se o invoice do tipo stripe for editado essa coluna deve ser true para que o stripe possa gerar um novo invoice

  percentageCoefficient Decimal?
  description           String?  @db.Text

  // Campos específicos para QuickBooks
  externalDocNumber String?

  // NOVOS CAMPOS PARA PAYMENT INTENT
  paymentMethodType        String? // Tipo do método de pagamento usado (card, us_bank_account, etc.)
  totalAmountPaid          Decimal? // Valor total pago (inclui surcharge)
  totalAmountWithSurcharge Decimal? // Valor original + surcharge

  // Relacionamento com Project e Company
  project   Project? @relation(name: "ProjectToInvoice", fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  company   Company? @relation(name: "CompanyToInvoice", fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?

  user_create User?   @relation(fields: [user_id], references: [id])
  user_id     String?

  estimate           Estimate?            @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId         String?
  // Relacionamentos
  InvoiceSendHistory InvoiceSendHistory[]
  InvoiceItems       InvoiceItem[] // Nova relação com InvoiceItem

  InvoiceTimeline InvoiceTimeline[]
  InvoiceEmailLog InvoiceEmailLog[]

  // Relação com CustomInvoicePayment (uma fatura pode ter um pagamento)
  payment    InvoicePayment?
  PdfProject PdfProject[]

  // Relacionamento com fildsPdfProject
  fildsPdfProjects fildsPdfProject[]

  // NOVO: Relacionamento com PaymentIntentRecord (para Payment Element)
  PaymentIntents PaymentIntentRecord[]

  @@index([externalInvoiceId, invoiceType])
}

model InvoiceSendHistory {
  id        String   @id @default(uuid())
  sentAt    DateTime @default(now())
  recipient String

  // Relacionamento com Invoice
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  user_create User?   @relation(fields: [user_id], references: [id])
  user_id     String?
}

model QuickBooksAccount {
  id                   String    @id @default(uuid())
  accessToken          String    @db.Text
  refreshToken         String    @db.Text
  realmId              String    @unique
  expiresAt            DateTime
  refreshExpiresAt     DateTime? // <- novo (opcional)
  needsReauthorization Boolean   @default(false)
  isDisabled           Boolean   @default(false)
  scopes               String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User?     @relation(fields: [user_id], references: [id])
  user_id              String?   @unique
  companyName          String?
  companyAddress       String?   @db.Text
  companyPhone         String?
  companyEmail         String?
  taxIdentifier        String?
  businessType         String?

  company    Company? @relation(fields: [company_id], references: [id])
  company_id String?  @unique
}

model InvoiceItem {
  id          String   @id @default(uuid())
  name        String // Nome do serviço ou item
  description String?  @db.Text // Descrição opcional do item
  quantity    Decimal // Quantidade
  price       Decimal // Preço unitário
  totalAmount Decimal // Valor total (quantidade * preço)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamento com Invoice
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String

  @@index([invoiceId])
}

model InvoicePayment {
  id            String   @id @default(uuid())
  paymentMethod String
  notes         String?  @db.Text
  amount        Float
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relação com Invoice (um pagamento pertence a uma fatura)
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String  @unique // Cada fatura pode ter apenas um registro de pagamento
}

enum TypeEstimate {
  estimate
  estimateProject
}

model Estimate {
  id              String   @id @default(uuid())
  number          String
  approvedAt      DateTime @default(now())
  clientSignature String?  @db.Text
  totalAmount     Decimal
  description     String?  @db.Text
  terms           String?  @db.Text
  status          String   @default("pending")

  amountPaid Decimal? @default(0)
  balanceDue Decimal? @default(0)

  type_estimate TypeEstimate? @default(estimateProject)
  multi_emails  String?       @db.Text

  canceledAt         DateTime?
  canceledById       String?
  cancellationReason String?   @db.Text

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  canceledBy User? @relation(name: "canceledEstimates", fields: [canceledById], references: [id], onDelete: Cascade)

  serviceProjects EstimateServiceProject[]
  timelineEvents  EstimateTimeline[]
  date_creation   DateTime                 @default(now())
  date_update     DateTime                 @updatedAt

  emailLogs  EstimateEmailLog[]
  PdfProject PdfProject[]

  // Relacionamento com fildsPdfProject
  fildsPdfProjects       fildsPdfProject[]
  Invoice                Invoice[]
  InvoicePaymentTimeLine InvoicePaymentTimeLine[]

  @@unique([number, projectId])
}

model EstimateTimeline {
  id            String   @id @default(uuid())
  description   String   @db.Text
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
  estimate      Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId    String
}

model EstimateServiceProject {
  id String @id @default(uuid())

  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId String

  name        String
  description String? @db.Text
  quantity    Int     @default(1)
  unitPrice   Decimal
  lineTotal   Decimal
  notes       String? @db.Text

  id_service String?
  service    Service? @relation(fields: [id_service], references: [id])

  hours      Decimal?
  price      Decimal?
  start_date String?
  deadline   String?

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
}

model Permissions {
  id String @id @default(uuid())

  description          String
  GroupPermissionsList GroupPermissionsList[]
  date_creation        DateTime               @default(now())
  date_update          DateTime               @updatedAt
}

model PermissionGroup {
  id String @id @default(uuid())

  description String

  GroupPermissionsList GroupPermissionsList[]
  plans                Plan[]
  date_creation        DateTime               @default(now())
  date_update          DateTime               @updatedAt
}

model GroupPermissionsList {
  id String @id @default(uuid())

  Permissions      Permissions     @relation(fields: [permission_id], references: [id])
  permission_id    String
  PermissionGroup  PermissionGroup @relation(fields: [permission_group], references: [id])
  permission_group String

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
}

model Subscription {
  id                             String    @id @default(uuid())
  companyId                      String
  company                        Company   @relation(fields: [companyId], references: [id])
  planId                         String
  plan                           Plan      @relation(fields: [planId], references: [id])
  startDate                      DateTime // Data de início da assinatura (quando o plano foi comprado)
  endDate                        DateTime // Data de fim do plano (quando o plano expira)
  isActive                       Boolean   @default(true) // Indica se o plano está ativo ou expirado
  stripeSubscriptionId           String?
  paymentFailed                  Boolean   @default(false)
  stripeSubscriptionCanceled     Boolean   @default(false)
  stripeDateSubscriptionCanceled DateTime? // Data em que a assinatura será cancelada (para cancelamentos agendados)
}

enum ValidityType {
  FREE
  MONTHLY
  ANNUAL
  CUSTOM
  DAYS
}

model Plan {
  id                String          @id @default(uuid())
  name              String
  description       String
  price             Decimal?
  features          Json? // Array de strings para armazenar as features do plano
  validityType      ValidityType // Tipo de validade (gratuito, mensal, etc.)
  validityDuration  Int // Duração da validade (ex: 15 para gratuito, 30 para mensal)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  permissionGroup   PermissionGroup @relation(fields: [permissionGroupId], references: [id])
  permissionGroupId String
  subscriptions     Subscription[] // Relaciona-se com as assinaturas
  Company           Company[]

  allowedEmployees Int?
  stripeProductId  String? // Campo para armazenar o ID do produto no Stripe
  stripePriceId    String? // Campo para armazenar o ID do preço no Stripe
}

model EstimateEmailLog {
  id           String   @id @default(uuid())
  recipient    String
  status       String // "success" ou "error"
  errorMessage String?  @db.Text
  sentAt       DateTime @default(now())

  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId String

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
}

model InvoiceTimeline {
  id            String   @id @default(uuid())
  description   String   @db.Text
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId     String
}

model InvoiceEmailLog {
  id           String   @id @default(uuid())
  recipient    String
  status       String // "success" ou "error"
  errorMessage String?  @db.Text
  sentAt       DateTime @default(now())

  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
}

enum PaymentIntentStatus {
  requires_payment_method // Initial state - waiting for payment method
  requires_confirmation // Payment method added, waiting for confirmation
  requires_action // Requires additional authentication (3D Secure, etc.)
  processing // Payment being processed (ACH settlement, bank transfers)
  requires_capture // Payment authorized, waiting for capture
  canceled // Payment was canceled before completion
  succeeded // Payment completed successfully
  payment_failed // Payment attempt failed
  disputed // Payment has been disputed/charged back
}

model PaymentIntentRecord {
  id                    String              @id @default(uuid())
  stripePaymentIntentId String              @unique
  status                PaymentIntentStatus // Payment status using enum
  amount                Decimal // Total PI amount (including surcharge if any)
  surchargeAmount       Decimal? // Surcharge amount passed to customer (if card)
  currency              String
  paymentMethodType     String? // "card" | "us_bank_account" | "customer_balance" etc.
  stripeAccountId       String // Connected account ID
  customerId            String? // Stripe customer ID
  receiptUrl            String? // Stripe receipt URL
  errorMessage          String? // Error details if payment fails
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // Link to internal invoice
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String

  @@index([invoiceId])
}

// Nova tabela de junção para relacionamento N:N entre User e Company
model UserCompany {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  createdAt DateTime @default(now())

  office_id String
  office    Office  @relation(fields: [office_id], references: [id])
  // Relacionamentos
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Constraint para evitar duplicatas
  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("user_company")
}

model SyncPreferences {
  id String @id @default(uuid())

  typesEntity TypesEntity
  typeSync    SyncType    @default(bidirectional) // Novo campo enum
  isDisable   Boolean     @default(false) // Campo para desabilitar sync

  userCreate User   @relation(name: "SyncPreferences", fields: [userId], references: [id])
  userId     String

  company   Company @relation(name: "SyncPreferences", fields: [companyId], references: [id])
  companyId String

  @@map("sync_preferences") // Renomeia a tabela no banco
}

enum TypesEntity {
  customers
  invoices
  payments
}

enum SyncType {
  bidirectional
  QuickBooksToSmartBuild
  SmartBuildToQuickBooks
}

model SyncLog {
  id        String   @id @default(uuid())
  entity    String // Ex.: "Client"
  action    String // Ex.: "Inserted", "Updated", "Skipped"
  entityId  String // ID do cliente
  timestamp DateTime @default(now())
  details   Json // Dados adicionais (ex.: diffs, erros)

  company   Company @relation(name: "synclog", fields: [companyId], references: [id])
  companyId String // ID da empresa associada

  // Relacionamento com execução (opcional para logs avulsos)
  syncExecution   SyncExecution? @relation(fields: [syncExecutionId], references: [id])
  syncExecutionId String?

  @@map("sync_log") // Renomeia a tabela no banco
}

model SyncStatus {
  id String @id @default(uuid())

  // Identificação da sincronização
  companyId String
  userId    String
  entity    TypesEntity // customers, invoices, payments
  syncType  SyncType // QuickBooksToSmartBuild, SmartBuildToQuickBooks, bidirectional

  // Status da sincronização ATUAL
  status        SyncStatusType @default(PENDING)
  lastSyncAt    DateTime? // Última sincronização bem-sucedida
  lastAttemptAt DateTime? // Última tentativa (sucesso ou falha)
  nextSyncAt    DateTime? // Próxima sincronização programada

  // Informações da última execução
  lastError  String? @db.Text
  errorCount Int     @default(0)

  // Metadados
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  company Company @relation(name: "SyncStatus", fields: [companyId], references: [id])
  user    User    @relation(name: "SyncStatus", fields: [userId], references: [id])

  // Relacionamento com histórico de execuções
  executions SyncExecution[]

  @@unique([companyId, userId, entity, syncType])
  @@map("sync_status")
}

model SyncExecution {
  id String @id @default(uuid())

  // Identificação da execução
  companyId String
  userId    String
  entity    TypesEntity
  syncType  SyncType

  // Status desta execução específica
  status      SyncStatusType @default(PENDING)
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  duration    Int? // duração em milissegundos

  // Controle de progresso desta execução
  totalRecords     Int @default(0)
  processedRecords Int @default(0)
  successRecords   Int @default(0)
  errorRecords     Int @default(0)

  // Informações de erro desta execução
  lastError String? @db.Text

  // Metadados adicionais
  triggerType String? // "manual", "scheduled", "webhook", "api"
  jobId       String? // ID do job no Bull/Redis
  details     Json? // dados extras sobre a execução

  // Relações
  syncStatus   SyncStatus @relation(fields: [syncStatusId], references: [id], onDelete: Cascade)
  syncStatusId String

  // Logs relacionados a esta execução
  logs SyncLog[]

  @@map("sync_execution")
}

enum SyncStatusType {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  PAUSED
}

model QuickBooksCustomerRaw {
  id           String   @id @default(uuid())
  companyId    String
  clientId     String? // <-- novo
  client       Client?  @relation(fields: [clientId], references: [id])
  quickbooksId String? // pode vir vazio quando der erro antes de criar no QBO
  payload      Json // Customer completo do QBO (ou o que você quiser logar)
  reason       String // DUPLICATE_EMAIL | MISSING_EMAIL | OTHER
  status       String // NEW | REVIEWED | IGNORED | MERGED
  detectedAt   DateTime @default(now())

  @@index([companyId])
  @@index([quickbooksId])
}

model QuickBooksOAuthState {
  id         String   @id @default(uuid())
  nonce      String   @unique
  userId     String
  companyId  String
  redirectTo String?
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("quickbooks_oauth_state")
}

model InvoicePaymentTimeLine {
  id String @id @default(uuid())

  description   String   @db.Text
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  estimateId String?
  estimate   Estimate? @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("invoice_payment_time_line")
}
