generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Config {
  id                  String  @id @default(uuid())
  multiCompanyEnabled Boolean @default(false)
}

model User {
  id                  String   @id @default(uuid())
  avatar              String?
  name                String
  email               String   @unique
  document            String?
  phone               String?
  phone_emergency     String?
  zip_code            String?
  city_and_state      String?
  state               String?
  number_road         String?
  number_home         String?
  neighborhood        String?
  password            String
  rules               Json
  hourly_price        Float?
  profession          String?
  isDisabled          Boolean? @default(false)
  isOverTime          Boolean? @default(false)
  onBoardingCompleted Boolean? @default(true)

  token_recover_password String?              @unique
  autorId                String?
  last_acess             DateTime?
  date_creation          DateTime             @default(now())
  date_update            DateTime             @updatedAt
  office_id              String
  office                 Office               @relation(fields: [office_id], references: [id])
  userLikedCostProject   CostProject[]        @relation("userLikedProject")
  seller_project         Project[]            @relation("seller")
  ServiceStages          ServiceStages[]
  projectId              String?
  UserServiceProject     UserServiceProject[]
  UserAttendance         UserAttendance[]
  Activities             Activities[]

  InvoiceSendHistory InvoiceSendHistory[]

  // Relacionamento original 1:N (mantido)
  company    Company? @relation(fields: [company_id], references: [id])
  company_id String?

  // Nova relação N:N através da tabela UserCompany
  companies UserCompany[]

  Invoice  Invoice[]
  TimeLine TimeLine[]

  quickBooksAccount    QuickBooksAccount?
  quickBooksAccount_id String?            @unique

  canceledEstimates Estimate[] @relation("canceledEstimates")
  Audit             Audit[]

  SyncPreferences SyncPreferences[] @relation("SyncPreferences")
  SyncStatus      SyncStatus[]      @relation("SyncStatus")

  // Relacionamentos do Feed
  FeedComments           FeedComment[]      @relation("FeedComments")
  FeedLikes              FeedLike[]         @relation("FeedLikes")
  FeedNotifications      FeedNotification[] @relation("FeedNotifications")
  FeedNotificationActors FeedNotification[] @relation("FeedNotificationActors")
  PublicFeedLinks        PublicFeedLink[]   @relation("PublicFeedLinkCreators")

  ProjectFiles     ProjectFiles[]
  ProjectPastes    ProjectPastes[]
  changeOrders     ChangeOrder[]
  tutorialProgress TutorialProgress[]

  // Sales CRM
  salesDeals      SalesDeal[]     @relation("AssignedDeals")
  salesActivities SalesActivity[] // Atividades realizadas pelo usuário

  @@index([office_id], map: "User_office_id_fkey")
}

model Audit {
  id            String   @id @default(uuid())
  action        String   @db.Text
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
  userId        String
}

model Company {
  id            String   @id @default(uuid())
  avatar        String?
  name          String
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
  address       String?
  district      String?
  numberHouse   String?
  complement    String?
  email         String?
  phone         String?
  webSiteUrl    String?
  workStartTime String? // Format: "HH:mm" (24-hour)
  workEndTime   String? // Format: "HH:mm" (24-hour)
  attendanceMode AttendanceMode @default(manual)

  // Relacionamento original 1:N (mantido)
  User User[]

  // Nova relação N:N através da tabela UserCompany
  userCompanies UserCompany[]

  Category         Category[]
  SubCategory      SubCategory[]
  Service          Service[]
  ServiceProject   ServiceProject[]
  Catalog          Catalog[]
  Project          Project[]
  Client           Client[]
  UserAttendance   UserAttendance[]
  allowedEmployees Int? // Quantidade de funcionários permitida pelo plano
  extraEmployees   Int? // Quantidade de funcionários extras adicionados

  invoices Invoice[] @relation(name: "CompanyToInvoice")

  NotesContrac ContractNotes[]

  stripeCustomerId String?

  // novo campo
  stripeAccountId String? @unique

  Subscription Subscription[]
  Plan         Plan?          @relation(fields: [planId], references: [id])
  planId       String?

  SyncPreferences   SyncPreferences[]  @relation("SyncPreferences")
  QuickBooksAccount QuickBooksAccount?

  SyncLog                SyncLog[]               @relation("synclog")
  SyncStatus             SyncStatus[]            @relation("SyncStatus")
  ContractTerms          ContractTerms[]
  QuickBooksConfig       QuickBooksConfig[]
  InvoiceAutoEmailConfig InvoiceAutoEmailConfig?

  workContexts WorkContext[]

  ProjectFiles   ProjectFiles[]
  ProjectPastes  ProjectPastes[]
  Subcontractors Subcontractor[]
  
  // NOVO: Pagamentos QBO
  paymentTransactions PaymentTransaction[]

  // Sales CRM
  salesDeals SalesDeal[] // Deals relacionados à empresa
}

model ContractNotes {
  id String @id @default(uuid())

  notes String @db.Text

  company    Company? @relation(fields: [company_id], references: [id])
  company_id String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Webhooks {
  id        String   @id @default(uuid())
  name      String // Nome do webhook
  event     String // Evento monitorado (ex.: checkout.session.completed)
  secret    String // Segredo do webhook
  url       String // URL associada ao webhook
  status    String // Status do webhook (ex.: "enabled", "disabled")
  stripeId  String   @unique // ID do webhook no Stripe
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // isConnectWebhook Boolean @default(false)

  @@map("webhooks")
}

model Office {
  id            String        @id @default(uuid())
  name          String
  date_creation DateTime      @default(now())
  date_update   DateTime      @updatedAt
  User          User[]
  UserCompany   UserCompany[]
}

model Rules {
  id            String   @id @default(uuid())
  name          String
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
}

model Category {
  id              String        @id @default(uuid())
  status_category Boolean?
  category_name   String
  autorId         String?
  date_creation   DateTime      @default(now())
  date_update     DateTime      @updatedAt
  category_img    String?
  type_category   String
  sub_category    SubCategory[]
  company         Company?      @relation(fields: [company_id], references: [id])
  company_id      String?

  @@map("service")
}

model SubCategory {
  id                 String    @id @default(uuid())
  status_subcategory Boolean?
  subcategory_name   String
  autorId            String?
  date_creation      DateTime  @default(now())
  date_update        DateTime  @updatedAt
  category_id        String
  subcategory        Category  @relation(fields: [category_id], references: [id])
  service            Service[]
  company            Company?  @relation(fields: [company_id], references: [id])
  company_id         String?

  @@index([category_id], map: "subcategory_category_id_fkey")
  @@map("subcategory")
}

model Service {
  id                     String                   @id @default(uuid())
  service_name           String
  type_variable          String
  price_type             String
  price_fixe             Decimal?
  price_minimum          Decimal?
  price_maximum          Decimal?
  autorId                String?
  date_creation          DateTime                 @default(now())
  date_update            DateTime                 @updatedAt
  service                SubCategory              @relation(fields: [sub_category_id], references: [id])
  sub_category_id        String
  ServiceProject         ServiceProject[]
  company                Company?                 @relation(fields: [company_id], references: [id])
  company_id             String?
  description            String?                  @db.Text
  EstimateServiceProject EstimateServiceProject[]

  @@index([sub_category_id], map: "variable_service_sub_category_id_fkey")
  @@map("variable_service")
}

model ServiceProject {
  id          String  @id @default(uuid())
  name        String
  description String  @db.Text
  hours       Decimal
  price       Decimal
  status      String?
  start_date  String?
  deadline    String?

  service    Service? @relation(fields: [id_service], references: [id])
  id_service String?

  stages             ServiceStages[]
  galleryBefore      GalleryBefore[]
  galleryAlfter      GalleryAfter[]
  photos             ImgServiceProject[]
  costProject        CostProject[]
  date_creation      DateTime             @default(now())
  date_update        DateTime             @updatedAt
  Project            Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId          String?
  UserServiceProject UserServiceProject[]
  Activities         Activities[]
  company            Company?             @relation(fields: [company_id], references: [id])
  company_id         String?
  TimeLine           TimeLine[]

  scheduleCompleted Boolean? @default(false)

  estimateServiceId            String?                       @unique
  estimateService              EstimateServiceProject?       @relation(fields: [estimateServiceId], references: [id])
  subServicesProjects          SubServicesProject[]
  subContractorServiceProjects SubContractorServiceProject[]
}

model SubServicesProject {
  id String @id @default(uuid())

  name        String
  description String? @db.Text
  quantity    Int     @default(1)
  price       Decimal
  status      String
  start_date  String?
  deadline    String?

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  scheduleCompleted Boolean? @default(false)

  serviceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?

  custom_service_schedule    CustomServiceSchedule? @relation(fields: [custom_service_schedule_id], references: [id], onDelete: Cascade)
  custom_service_schedule_id String?

  userServiceProject           UserServiceProject[]
  subContractorServiceProjects SubContractorServiceProject[]

  @@map("sub_services_project")
}

model CustomServiceSchedule {
  id String @id @default(uuid())

  name        String
  description String? @db.Text
  start_date  String?
  deadline    String?

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  scheduleCompleted Boolean? @default(false)

  subServicesProjects          SubServicesProject[]
  userServiceProjects          UserServiceProject[]
  subContractorServiceProjects SubContractorServiceProject[]

  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?

  @@map("custom_service_schedule")
}

model Activities {
  id   String @id @default(uuid())
  text String @db.Text

  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?

  author   User?   @relation(fields: [authorId], references: [id])
  authorId String?

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  // Novos relacionamentos para feed
  comments      FeedComment[]
  likes         FeedLike[]
  notifications FeedNotification[]
}

model FeedComment {
  id   String @id @default(uuid())
  text String @db.Text

  activity   Activities @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId String

  author   User   @relation("FeedComments", fields: [authorId], references: [id])
  authorId String

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  @@index([activityId])
  @@index([authorId])
  @@map("feed_comment")
}

model FeedLike {
  id String @id @default(uuid())

  activity   Activities @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId String

  user   User   @relation("FeedLikes", fields: [userId], references: [id])
  userId String

  date_creation DateTime @default(now())

  @@unique([activityId, userId]) // Um usuário só pode dar 1 like por post
  @@index([activityId])
  @@index([userId])
  @@map("feed_like")
}

model FeedNotification {
  id String @id @default(uuid())

  type        String // "comment", "like", "mention"
  message     String  @db.Text
  isRead      Boolean @default(false)
  relatedLink String? // Link para o post/comentário

  // Destinatário da notificação
  user   User   @relation("FeedNotifications", fields: [userId], references: [id])
  userId String

  // Quem gerou a notificação (quem comentou/curtiu)
  actor   User?   @relation("FeedNotificationActors", fields: [actorId], references: [id])
  actorId String?

  // Post relacionado
  activity   Activities? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId String?

  date_creation DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([activityId])
  @@map("feed_notification")
}

// Links públicos para compartilhar feed de projeto com clientes
model PublicFeedLink {
  id    String @id @default(uuid())
  token String @unique @db.VarChar(255) // Token único para acesso público

  // Relacionamento com projeto (single project - legacy)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?

  // Relacionamento N:N com múltiplos projetos (novo)
  projects PublicFeedLinkProject[]

  // Quem criou o link
  creator   User   @relation("PublicFeedLinkCreators", fields: [createdBy], references: [id])
  createdBy String

  // Status e configurações
  isActive     Boolean   @default(true)
  expiresAt    DateTime? // Opcional: data de expiração
  accessCount  Int       @default(0) // Contador de acessos
  lastAccessAt DateTime? // Último acesso

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  @@index([token])
  @@index([projectId])
  @@index([isActive])
}

// Tabela de relacionamento N:N entre PublicFeedLink e Project
model PublicFeedLinkProject {
  id String @id @default(uuid())

  // Relacionamento com PublicFeedLink
  publicFeedLink   PublicFeedLink @relation(fields: [publicFeedLinkId], references: [id], onDelete: Cascade)
  publicFeedLinkId String

  // Relacionamento com Project
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  date_creation DateTime @default(now())

  @@unique([publicFeedLinkId, projectId])
  @@index([publicFeedLinkId])
  @@index([projectId])
}

model ImgServiceProject {
  id               String          @id @default(uuid())
  uri              String          @unique
  date_creation    DateTime        @default(now())
  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?
}

model Catalog {
  id            String   @id @default(uuid())
  catalog_img   String?
  catalog_name  String
  autorId       String?
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  imgCatalog ImgCatalog[]
  company    Company?     @relation(fields: [company_id], references: [id])
  company_id String?

  @@map("catalog")
}

model ImgCatalog {
  id  String @id @default(uuid())
  uri String @unique

  data_criacao DateTime @default(now())
  authorId     String?

  catalog    Catalog @relation(fields: [catalog_id], references: [id])
  catalog_id String

  @@map("imgcatalog")
}

model Project {
  id                 String               @id @default(uuid())
  contract_number    Int?
  price              Decimal
  status_project     String
  autorId            String?
  start_date         String?
  deadline           String?
  date_creation      DateTime             @default(now())
  date_update        DateTime             @updatedAt
  invoiceCostProject InvoiceCostProject[]
  serviceProject     ServiceProject[]
  workedHours        Workedhours[]
  pdfproject         PdfProject[]
  contractProject    ContractProject[]
  estimates          Estimate[]

  amountPaid Decimal? @default(0)
  balanceDue Decimal?

  invoices Invoice[] @relation(name: "ProjectToInvoice")

  client    Client? @relation(fields: [client_id], references: [id])
  client_id String?

  user           User?    @relation("seller", fields: [seller_user_id], references: [id])
  seller_user_id String?
  company        Company? @relation(fields: [company_id], references: [id])
  company_id     String?

  workContext   WorkContext? @relation(fields: [workContextId], references: [id])
  workContextId String?

  radius                 Float?
  location               String?                  @db.Text
  log                    String?                  @db.VarChar(191)
  lat                    String?                  @db.VarChar(191)
  cover_photo            String?                  @db.Text
  InvoicePaymentTimeLine InvoicePaymentTimeLine[]
  projectFiles           ProjectFiles[]
  projectPastes          ProjectPastes[]
  PublicFeedLinks        PublicFeedLink[]
  PublicFeedLinkProjects PublicFeedLinkProject[]
  imagesAttachments      ImagesAttachments[]
  customServiceSchedules CustomServiceSchedule[]

  @@index([client_id], map: "project_client_id_fkey")
  @@index([seller_user_id], map: "project_seller_user_id_fkey")
  @@index([workContextId])
  @@map("project")
}

model ContractProject {
  id                 String   @id @default(uuid())
  original_file_name String?
  uri                String?
  date_creation      DateTime @default(now())
  date_update        DateTime @updatedAt

  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?

  @@map("contract_project")
}

model ServiceStages {
  id            String   @id @default(uuid())
  description   String
  check         Boolean  @default(false)
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  user             User            @relation(fields: [id_user_update], references: [id])
  id_user_update   String
  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?
}

model GalleryBefore {
  id               String          @id @default(uuid())
  url              String
  title            String?
  description      String?
  date_creation    DateTime        @default(now())
  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?
}

model GalleryAfter {
  id               String          @id @default(uuid())
  url              String
  title            String?
  description      String?
  date_creation    DateTime        @default(now())
  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?
}

model PdfProject {
  id                 String  @id @default(uuid())
  original_file_name String?
  uri                String?

  project    Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String?

  templateNumber Int? @default(1)

  // vinculo com estimate
  estimate    Estimate? @relation(fields: [estimate_id], references: [id], onDelete: Cascade)
  estimate_id String?

  // vinculo com invoice
  invoice    Invoice? @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id String?

  changeOrder   ChangeOrder? @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  changeOrderId String?

  type_pdf String?

  // Relacionamento com fildsPdfProject
  fildsPdfProjects fildsPdfProject[]

  autorId       String?
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  @@map("pdf_project")
}

model PdfInvoicePaid {
  id String @id @default(uuid())

  original_file_name String?
  uri                String?

  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String?

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  @@unique([invoiceId])
  @@map("pdf_invoice_paid")
}

model fildsPdfProject {
  id          String  @id @default(uuid())
  sections    String
  description String? @db.Text

  // Relacionamentos
  pdfProject   PdfProject? @relation(fields: [pdfProjectId], references: [id], onDelete: Cascade)
  pdfProjectId String?

  estimate   Estimate? @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId String?

  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String?

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt
}

model Client {
  id               String    @id @default(uuid())
  avatar           String?
  name             String
  email            String
  document         String?
  phone            String?
  city_and_state   String?
  birth_date       String?
  location         String?   @db.Text
  addressOffice    String?   @db.Text
  lat              String?
  log              String?
  radius           Float?
  autorId          String?
  date_creation    DateTime  @default(now())
  date_update      DateTime  @updatedAt
  projects         Project[]
  company          Company?  @relation(fields: [company_id], references: [id])
  company_id       String?
  stripeCustomerId String?
  sync_version     Int       @default(0)

  quickbooksUpdatedAt DateTime?

  idQuickbooks          String?
  QuickBooksCustomerRaw QuickBooksCustomerRaw[]
  workContexts          WorkContext[]

  @@unique([idQuickbooks, company_id])
  @@unique([email, company_id])
}

enum ContextType {
  COMPANY
  PERSONAL
}

model WorkContext {
  id String @id @default(uuid())

  type  ContextType
  label String? // 

  Name  String?
  Email String?

  street         String?
  district       String?
  zip_code       String?
  city_and_state String?
  state          String?
  number         String?
  complement     String?
  phone          String?

  location      String?  @db.Text
  addressOffice String?  @db.Text
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  radius        Float?

  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  notes    String? @db.Text
  isActive Boolean @default(true)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([type])
  @@map("work_context")
}

model InvoiceCostProject {
  id                          String        @id @default(uuid())
  original_file_name          String?
  uri                         String?
  project_cost_invoice_exists Boolean
  autorId                     String?
  date_creation               DateTime      @default(now())
  date_update                 DateTime      @updatedAt
  project_id                  String?
  costProject                 CostProject[]
  project                     Project?      @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id], map: "invoice_cost_project_project_id_fkey")
  @@map("invoice_cost_project")
}

model CostProject {
  id            String    @id @default(uuid())
  material_name String
  price         Decimal
  amout         Int
  cost_date     DateTime?

  transaction_type        String?
  userId                  String?
  autorId                 String?
  date_creation           DateTime            @default(now())
  date_update             DateTime            @updatedAt
  invoiceCostProject      InvoiceCostProject? @relation(fields: [invoice_cost_project_id], references: [id], onDelete: Cascade)
  invoice_cost_project_id String?
  user                    User?               @relation("userLikedProject", fields: [userId], references: [id])

  ServiceProject   ServiceProject? @relation(fields: [serviceProjectId], references: [id], onDelete: Cascade)
  serviceProjectId String?

  @@index([invoice_cost_project_id], map: "cost_project_invoice_cost_project_id_fkey")
  @@index([userId], map: "cost_project_userId_fkey")
  @@map("cost_project")
}

model Subcontractor {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String?
  address       String?
  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  workedHours Workedhours[]

  company                      Company?                      @relation(fields: [company_id], references: [id])
  company_id                   String?
  subContractorServiceProjects SubContractorServiceProject[]

  @@map("subcontractors")
}

model Workedhours {
  id String @id @default(uuid())

  name_user String

  start_date String?

  end_date String?

  amount_of_hours Decimal?
  hourly_price    Decimal

  description  String?
  payment_date DateTime?

  date_creation DateTime @default(now())
  date_update   DateTime @updatedAt

  project    Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String?

  subcontractor    Subcontractor? @relation(fields: [subcontractor_id], references: [id])
  subcontractor_id String?

  @@map("worked_hours")
}

// Relacionamento entre User e ServiceProject
model UserServiceProject {
  id          String   @id @default(uuid())
  assigned_at DateTime @default(now())

  user    User   @relation(fields: [user_id], references: [id])
  user_id String

  service_project    ServiceProject? @relation(fields: [service_project_id], references: [id], onDelete: Cascade)
  service_project_id String?

  sub_service_project    SubServicesProject? @relation(fields: [sub_service_project_id], references: [id], onDelete: Cascade)
  sub_service_project_id String?

  custom_service_schedule    CustomServiceSchedule? @relation(fields: [custom_service_schedule_id], references: [id], onDelete: Cascade)
  custom_service_schedule_id String?

  user_attendances UserAttendance[]
  TimeLine         TimeLine[]

  @@unique([user_id, service_project_id], map: "user_service_project_unique")
  @@unique([user_id, sub_service_project_id], map: "user_service_project_unique_sub_service_unique")
  @@unique([user_id, custom_service_schedule_id], map: "user_service_project_unique_custom_schedule")
  @@index([user_id], map: "user_service_project_user_id_fkey")
  @@index([service_project_id], map: "user_service_project_service_project_id_fkey")
  @@index([sub_service_project_id], map: "user_service_project_sub_service_project_id_fkey")
  @@index([custom_service_schedule_id], map: "user_service_project_custom_schedule_id_fkey")
  @@map("user_service_project")
}

