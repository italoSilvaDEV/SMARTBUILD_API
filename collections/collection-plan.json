            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"newEndDate\": \"2025-12-31T23:59:59Z\"\n}"
            },
            "description": "Renova uma assinatura com nova data de término"
          }
        }
