      "item": [
        {
          "name": "Listar todas as assinaturas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["subscriptions"]
            },
            "description": "Lista todas as assinaturas cadastradas"
          }
        },
        {
          "name": "Buscar assinatura por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/subscriptions/{{subscription_id}}",
              "host": ["{{base_url}}"],
              "path": ["subscriptions", "{{subscription_id}}"]
            },
            "description": "Busca uma assinatura específica pelo ID"
          }
        },
        {
          "name": "Listar assinaturas de uma empresa",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/companies/{{company_id}}/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["companies", "{{company_id}}", "subscriptions"]
            },
            "description": "Lista todas as assinaturas de uma empresa específica"
          }
        },
        {
          "name": "Criar nova assinatura",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/subscriptions",
              "host": ["{{base_url}}"],
              "path": ["subscriptions"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"companyId\": \"{{company_id}}\",\n    \"planId\": \"{{plan_id}}\",\n    \"startDate\": \"2023-01-01T00:00:00Z\",\n    \"endDate\": \"2023-12-31T23:59:59Z\"\n}"
            },
            "description": "Cria uma nova assinatura para uma empresa"
          }
        },
        {
          "name": "Atualizar assinatura",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/subscriptions/{{subscription_id}}",
              "host": ["{{base_url}}"],
              "path": ["subscriptions", "{{subscription_id}}"]
