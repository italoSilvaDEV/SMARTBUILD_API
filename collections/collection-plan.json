            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"planId\": \"{{plan_id}}\",\n    \"startDate\": \"2023-01-01T00:00:00Z\",\n    \"endDate\": \"2024-12-31T23:59:59Z\",\n    \"isActive\": true\n}"
            },
            "description": "Atualiza uma assinatura existente"
          }
        },
        {
          "name": "Cancelar assinatura",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/subscriptions/{{subscription_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["subscriptions", "{{subscription_id}}", "cancel"]
