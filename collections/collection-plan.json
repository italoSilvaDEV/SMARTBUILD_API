  "item": [
    {
      "name": "Permissões",
      "item": [
        {
          "name": "Listar todas as permissões",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/permissions",
              "host": ["{{base_url}}"],
              "path": ["permissions"]
            },
            "description": "Lista todas as permissões cadastradas no sistema"
          }
        },
        {
          "name": "Buscar permissão por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/permissions/{{permission_id}}",
              "host": ["{{base_url}}"],
              "path": ["permissions", "{{permission_id}}"]
            },
            "description": "Busca uma permissão específica pelo ID"
          }
        },
        {
          "name": "Criar nova permissão",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/permissions",
              "host": ["{{base_url}}"],
              "path": ["permissions"]
