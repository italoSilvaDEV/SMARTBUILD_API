            "body": {
              "mode": "raw",
              "raw": "{\n    \"description\": \"Visualizar Dashboard\"\n}"
            },
            "description": "Cria uma nova permissão no sistema"
          }
        },
        {
          "name": "Atualizar permissão",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/permissions/{{permission_id}}",
              "host": ["{{base_url}}"],
              "path": ["permissions", "{{permission_id}}"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"description\": \"Visualizar Dashboard Financeiro\"\n}"
            },
            "description": "Atualiza uma permissão existente"
          }
        },
        {
          "name": "Excluir permissão",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/permissions/{{permission_id}}",
              "host": ["{{base_url}}"],
              "path": ["permissions", "{{permission_id}}"]
            },
            "description": "Remove uma permissão do sistema (se não estiver em uso)"
          }
        }
