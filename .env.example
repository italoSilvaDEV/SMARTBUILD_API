# ===========================================
# SmartBuild API - Environment Variables
# ===========================================

# Database
DATABASE_URL="mysql://user:password@localhost:3306/smartbuild"

# JWT Secret
SECRET_JWT=your-secret-key-here

# URLs
URL_FRONT="http://localhost:5173"
URL_API="http://localhost:4003"

# QuickBooks Integration
QUICKBOOKS_CLIENT_ID=your-client-id
QUICKBOOKS_CLIENT_SECRET=your-client-secret
QBO_WEBHOOK_VERIFIER_TOKEN=your-webhook-verifier-token
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_CALLBACK_PATH="/quickbooks/callback"

# Redis
REDIS_URL="redis://127.0.0.1:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Stripe Extra Employee Product
# Default price in cents (e.g., 1000 = $10.00)
# This value is used only when creating the ExtraEmployeeConfig for the first time
# After that, the price is managed via the database
STRIPE_PRICE_EXTRA_EMPLOYEE=1000

# Rewardful
REWARDFUL_API_SECRET=your-rewardful-api-secret
REWARDFUL_API_KEY=your-rewardful-api-key
